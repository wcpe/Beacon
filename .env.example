# Beacon 部署环境变量样例。复制为 .env 并填真实值。
# .env 已被 .gitignore 排除，切勿提交真实密码。

# —— MySQL（配置权威库）——
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=beacon
MYSQL_USER=beacon
MYSQL_PASSWORD=change-me

# —— Beacon 控制面 ——
# agent 端共享 token，仅防误连（非安全边界，见 SECURITY.md）
BEACON_BOOTSTRAP_TOKEN=change-me-bootstrap-token
# API 与管理台监听端口（二者同端口）
BEACON_HTTP_ADDR=:8848

# —— 管理面鉴权（FR-11，见 docs/adr/0009）——
# 管理台操作者用户名（可缺省，默认 admin）
BEACON_ADMIN_USERNAME=admin
# 管理台操作者口令（敏感项，必填，切勿提交真实值）
BEACON_ADMIN_PASSWORD=change-me-admin-password
# 登录令牌 HMAC 签名密钥（敏感项，必填，建议长随机串）
BEACON_AUTH_SECRET=change-me-auth-secret
