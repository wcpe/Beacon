# IDE / 操作系统
/.idea/
.vscode/
*.iml
.DS_Store
Thumbs.db

# 过程性文档与临时文件（不入库，遵 .claude/rules/git-commit）
/.tmp/
.narrafork/
package-lock.json

# 环境与密钥（不入库）
.env

# Go 控制面
/beacon
/bin/
*.exe
*.out

# 打包产物（make package / release 输出，不入库）
/dist/

# 前端 React / Vite
/web/node_modules/
# 忽略 dist 内构建产物，但保留占位 .gitkeep（供后端 go:embed all:web/dist 在未构建前端时仍可编译）
# 注意：须忽略目录内容（/web/dist/*）而非目录本身，否则父目录被排除会使下面的 .gitkeep 例外失效
/web/dist/*
!/web/dist/.gitkeep

# Kotlin / Gradle agent
/agent/.gradle/
/agent/**/build/
/agent/**/.gradle/


/config.yaml
/beacon.db

# 首启运行时生成的控制面配置（embed 源为 config.example.yml），不入库
/config.yml
